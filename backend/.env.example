# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/ai-fortune

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 智谱AI配置
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v3/model-api

# 微信配置
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# 支付配置
WECHAT_PAY_MCHID=your-merchant-id
WECHAT_PAY_KEY=your-wechat-pay-key
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/pay/callback/wechat

# 业务配置
ORDER_PREFIX=ORD
DEFAULT_PAGE_SIZE=20
